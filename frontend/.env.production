# Production build-time config for Vercel.
# VITE_* values are PUBLIC (baked into the client bundle) — not secrets — so this file is committed.
# Backend runs on the Oracle VPS behind Caddy at this hostname (see AiApp/deploy/).
# You can also override this in the Vercel dashboard (Settings -> Environment Variables).
VITE_API_BASE_URL=https://api.stockvision.praxivo.in/api/v1
