# ── Application ──────────────────────────────────────────────
APP_NAME=StockVision API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development        # development | staging | production

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,https://stockvision.in

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:<password>@localhost:5432/stockvision
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Auth (JWT) ───────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15      # short-lived; refresh token handles renewal
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Field Encryption (PAN, broker tokens) ────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=300

# ── AI ────────────────────────────────────────────────────────
# Generate at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Market Data ───────────────────────────────────────────────
ALPHA_VANTAGE_KEY=
FMP_API_KEY=
ANGELONE_API_KEY=
ZERODHA_API_KEY=
ICICI_API_KEY=

# ── Bhashini (Hindi AI) ───────────────────────────────────────
BHASHINI_USER_ID=
BHASHINI_API_KEY=

# ── Razorpay (Payments) ───────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Generate in Razorpay dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=

# ── SendGrid (Email) ──────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@stockvision.in

# ── Sentry (Error tracking) ───────────────────────────────────
SENTRY_DSN=
